<?xml version="1.0" ?>
<!--
  Simplified URDF for FANUC LR Mate 200iD/14L
  Dimensions based on DH parameters (mm converted to m for URDF):
    d1=330mm, a1=75mm, a2=450mm, a3=75mm, d4=450mm, d6=80mm
  All lengths in meters for URDF convention.
-->
<robot name="lrmate200id14l">

  <!-- Materials -->
  <material name="fanuc_yellow">
    <color rgba="0.96 0.75 0.05 1.0"/>
  </material>
  <material name="dark_grey">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <material name="silver">
    <color rgba="0.75 0.75 0.75 1.0"/>
  </material>
  <material name="knife_steel">
    <color rgba="0.8 0.8 0.85 1.0"/>
  </material>
  <material name="knife_handle">
    <color rgba="0.25 0.15 0.1 1.0"/>
  </material>

  <!-- Base link (world / floor mount) -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.165" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.33"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.165" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.33"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="20.0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.05"/>
    </inertial>
  </link>

  <!-- Joint 1: Rotation around Z axis -->
  <joint name="joint_1" type="revolute">
    <parent link="base_link"/>
    <child link="link_1"/>
    <origin xyz="0 0 0.330" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.9671" upper="2.9671" effort="200" velocity="3.14"/>
  </joint>

  <!-- Link 1 (shoulder) -->
  <link name="link_1">
    <visual>
      <origin xyz="0.0375 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.055" length="0.075"/>
      </geometry>
      <material name="fanuc_yellow"/>
    </visual>
    <collision>
      <origin xyz="0.0375 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.055" length="0.075"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="8.0"/>
      <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.02"/>
    </inertial>
  </link>

  <!-- Joint 2: Rotation around Y axis (with -90 deg DH offset) -->
  <joint name="joint_2" type="revolute">
    <parent link="link_1"/>
    <child link="link_2"/>
    <origin xyz="0.075 0 0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.4835" upper="2.5307" effort="200" velocity="3.14"/>
  </joint>

  <!-- Link 2 (upper arm) -->
  <link name="link_2">
    <visual>
      <origin xyz="0.225 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <box size="0.06 0.07 0.45"/>
      </geometry>
      <material name="fanuc_yellow"/>
    </visual>
    <collision>
      <origin xyz="0.225 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <box size="0.06 0.07 0.45"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="6.0"/>
      <inertia ixx="0.03" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
  </link>

  <!-- Joint 3 -->
  <joint name="joint_3" type="revolute">
    <parent link="link_2"/>
    <child link="link_3"/>
    <origin xyz="0.450 0 0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.0543" upper="4.4506" effort="100" velocity="3.14"/>
  </joint>

  <!-- Link 3 (forearm) -->
  <link name="link_3">
    <visual>
      <origin xyz="0.0375 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.045" length="0.075"/>
      </geometry>
      <material name="fanuc_yellow"/>
    </visual>
    <collision>
      <origin xyz="0.0375 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.045" length="0.075"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="4.0"/>
      <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <!-- Joint 4: Wrist roll -->
  <joint name="joint_4" type="revolute">
    <parent link="link_3"/>
    <child link="link_4"/>
    <origin xyz="0.075 0 0" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.3161" upper="3.3161" effort="50" velocity="6.28"/>
  </joint>

  <!-- Link 4 (wrist body) -->
  <link name="link_4">
    <visual>
      <origin xyz="0 0 0.225" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.45"/>
      </geometry>
      <material name="fanuc_yellow"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.225" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.45"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.005"/>
    </inertial>
  </link>

  <!-- Joint 5: Wrist bend -->
  <joint name="joint_5" type="revolute">
    <parent link="link_4"/>
    <child link="link_5"/>
    <origin xyz="0 0 0.450" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.3562" upper="2.3562" effort="50" velocity="6.28"/>
  </joint>

  <!-- Link 5 (wrist pitch) -->
  <link name="link_5">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.035"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.035"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005"/>
    </inertial>
  </link>

  <!-- Joint 6: Tool rotation -->
  <joint name="joint_6" type="revolute">
    <parent link="link_5"/>
    <child link="link_6"/>
    <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.2832" upper="6.2832" effort="30" velocity="10.0"/>
  </joint>

  <!-- Link 6 (flange) -->
  <link name="link_6">
    <visual>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.03" length="0.08"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.03" length="0.08"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <!-- Tool flange joint -->
  <joint name="joint_flange" type="fixed">
    <parent link="link_6"/>
    <child link="tool_flange"/>
    <origin xyz="0 0 0.080" rpy="0 0 0"/>
  </joint>

  <!-- Tool flange link -->
  <link name="tool_flange">
    <visual>
      <origin xyz="0 0 0.005" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.032" length="0.01"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- Knife mounting bracket -->
  <joint name="joint_knife_mount" type="fixed">
    <parent link="tool_flange"/>
    <child link="knife_handle_link"/>
    <origin xyz="0 0 0.01" rpy="0 0 0"/>
  </joint>

  <!-- Knife handle -->
  <link name="knife_handle_link">
    <visual>
      <origin xyz="0 0 0.075" rpy="0 0 0"/>
      <geometry>
        <box size="0.025 0.015 0.150"/>
      </geometry>
      <material name="knife_handle"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.075" rpy="0 0 0"/>
      <geometry>
        <box size="0.025 0.015 0.150"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- Knife blade joint -->
  <joint name="joint_knife_blade" type="fixed">
    <parent link="knife_handle_link"/>
    <child link="knife_blade_link"/>
    <origin xyz="0 0 0.150" rpy="0 0 0"/>
  </joint>

  <!-- Knife blade (200mm long, thin rectangular) -->
  <link name="knife_blade_link">
    <visual>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <geometry>
        <!-- blade: 3mm thick, 45mm wide (spine to edge), 200mm long -->
        <box size="0.003 0.045 0.200"/>
      </geometry>
      <material name="knife_steel"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <geometry>
        <box size="0.003 0.045 0.200"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- Knife tip (TCP) -->
  <joint name="joint_knife_tip" type="fixed">
    <parent link="knife_blade_link"/>
    <child link="knife_tip"/>
    <origin xyz="0 0 0.200" rpy="0 0 0"/>
  </joint>

  <link name="knife_tip">
    <inertial>
      <mass value="0.001"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
  </link>

</robot>
